@page
@using Microsoft.AspNetCore.Components.Web
@using CAHFS_Emailer.Models
@model CAHFS_Emailer.Pages.EmailsModel
@{
    var emails = ViewData["Emails"] as List<EmailWithAttachments>;
    var pageLinkBase = $"?StartDate={Model.StartDate.ToString("yyyy-MM-dd")}&EndDate={Model.EndDate.ToString("yyyy-MM-dd")}&Status={Model.Status}&";
}

<form method="get">
    <div class="row">

        <div class="mb-3 col">
            <label asp-for="StartDate" class="form-label">Start Date:</label>
            <input asp-for="StartDate" class="form-control" type="date" required />
        </div>

        <div class="mb-3 col">
            <label asp-for="EndDate" class="form-label">End Date:</label>
            <input asp-for="EndDate" class="form-control" type="date" required />
        </div>

        <div class="mb-3 col">
            <label asp-for="Status" class="form-label">Status:</label>
            <select asp-for="Status" class="form-control">
                <option value="">All</option>
                <option value="SENT">Sent</option>
                <option value="PENDING">Pending</option>
                <option value="INPROCESS">In Process</option>
                <option value="ERROR">Error</option>
            </select>
        </div>

        <button type="submit" class="btn btn-primary">Search</button>
    
    </div>
</form>

<ul class="pagination">
    <li class="page-item @(Model.PageNumber == 1 ? "disabled" : "")">
        <a class="page-link button" href="@(pageLinkBase)PageNumber=1">First</a>
    </li>
    <li class="page-item @(Model.PageNumber == 1 ? "disabled" : "")">
        <a class="page-link button" href="@(pageLinkBase)PageNumber=@(Model.PageNumber - 1)">Previous</a>
    </li>

    @for (int i = 1; i <= @Model.PageCount && i <= 5; i++)
    {
        int pageNumber = i;
        <li class="page-item @(Model.PageNumber == i ? "active" : "")">
            <a class="page-link button" href="@(pageLinkBase)PageNumber=@pageNumber">@i</a>
        </li>
    }

    <li class="page-item @(Model.PageNumber == Model.PageCount ? "disabled" : "")">
        <a class="page-link button" href="@(pageLinkBase)PageNumber=@(Model.PageNumber + 1)">Next</a>
    </li>
    <li class="page-item @(Model.PageNumber == Model.PageCount ? "disabled" : "")">
        <a class="page-link button" href="@(pageLinkBase)PageNumber=@Model.PageCount">Last</a>
    </li>
</ul>

<table cellpadding="3">
    <thead>
        <tr valign="top">
            <th>FOLDERNO</th>
            <th>Added</th>
            <th>From / To /CC / BCC</th>
            <th width="30%">Subject</th>
            <th>Status</th>
            <th>Sent At</th>
            <th>Attachments</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var e in emails ?? [])
        {
            <tr valign="top">
                <td>@e.Email.FolderNo</td>
                <td>@e.Email.InsertedAt</td>
                <td>
                    @e.Email.FromAddress
                    <br/>
                    @e.Email.ToAddresses
                    <br/>
                    
                    @if (!String.IsNullOrEmpty(e.Email.CcAddresses))
                    {
                        @e.Email.CcAddresses
                        <br/>
                    }
                    @if (!String.IsNullOrEmpty(e.Email.BccAddresses)) 
                    {
                        @e.Email.BccAddresses
                        <br/>
                    }
                </td>
                <td>
                    @e.Email.SubjectLine
                </td>
                <td>
                    @e.Email.Status
                    <br/>
                    @e.Email.ErrorMessage
                </td>
                <td>@e.Email.SentAt</td>
                <td>
                    @e.Email.AttachmentCount
                    @if (e.Email.AttachmentCount > 0 && e.Email.AttachmentId != null && e.Email.AttachmentId > 0)
                    {
                        <a href="ViewAttachment?id=@e.Email.AttachmentId">View</a>
                    }
                </td>
            </tr>
        }
        @if (emails == null || emails.Count == 0)
        {
            <tr>
                <td colspan="11">No emails found for the specified criteria.</td>
            </tr>
        }
    </tbody>
</table>